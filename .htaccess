# RewriteEngine On

# Force HTTPS (uncomment if using SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Disable directory listing
Options -Indexes

# Allow access to files and directories
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
